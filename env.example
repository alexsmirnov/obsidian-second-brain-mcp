# OpenAI-compatible model router base URL. Required for any AI feature
# (web research and Obsidian RAG embeddings/inference). Leave empty to
# disable all router-backed tools.
ROUTER_API_BASE=http://localhost:4000

# Authentication token for the model router above.
ROUTER_API_KEY=sk-router-token

# Embedding model name served by the router. Used to index and query
# Obsidian vault chunks. Empty disables vault indexing/search.
RAG_EMBEDDING_MODEL=text-embedding-3-small

# Vector dimension for the embedding model above. Must match the model's
# output size or LanceDB schema creation will fail.
RAG_EMBEDDING_DIMENSIONS=1536

# Optional reranker model served by the router. When set, LanceDB uses it
# for DB-level reranking. Empty falls back to local RRF/LlmReranker logic.
RAG_RERANKER_MODEL=gpt-4o-mini

# Optional chat model for search-level HyDE generation and structured
# reranking. Empty keeps vault search vector-only.
RAG_INFER_MODEL=

# Optional chat model used by the local LLM reranker when no proxy
# reranker is configured. Empty disables LLM-based reranking.
RAG_RERANKER_INFER_MODEL=gemini-flash-lite

# Optional embedding model used by the local LLM reranker. Empty reuses
# RAG_EMBEDDING_MODEL.
RAG_RERANKER_EMBEDDING_MODEL=

# Vector dimension for RAG_RERANKER_EMBEDDING_MODEL above. Ignored when
# that model is empty.
RAG_RERANKER_EMBEDDING_DIMENSIONS=768

# Fast/cheap chat model for web research query generation and result
# cleanup. Empty disables web research.
RESEARCH_FAST_MODEL=gemini-flash-lite

# Stronger chat model for web research reflection and final answer
# synthesis. Empty disables web research.
RESEARCH_INFER_MODEL=gemini-flash

# Optional Anthropic API key for non-RAG integrations.
ANTHROPIC_API_KEY=sk-ant-...

# Google Custom Search API key. Required only when using Google instead of
# DuckDuckGo for web research.
GOOGLE_API_KEY=

# Google Custom Search Engine ID. Required only when GOOGLE_API_KEY is set.
GOOGLE_SEARCH_ID=

# Absolute path to the Obsidian vault root. Empty disables vault tools.
VAULT=/Users/username/Documents/ObsidianVault
